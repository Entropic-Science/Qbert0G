# Qbert0G configuration
# Copy to config.yaml and customize. Validation is strict: unknown keys
# are rejected at startup (a typo must never change what randomness is served).

# ── Wire / transport ─────────────────────────────────────────────────────────
server:
  # TCP bind (host:port). 127.0.0.1 keeps the service on-box; bind 0.0.0.0
  # ONLY if you deliberately want to serve entropy to other machines.
  listen: "127.0.0.1:50051"
  # UNIX domain socket — the preferred transport for co-located clients
  # (lowest latency). Leave empty to disable. Not available on Windows.
  unix_socket: ""
  request_timeout: 5.0        # seconds to wait for an available device
  max_message_size: 16777216  # 16 MB
  failover_enabled: true      # route to another device if the primary is busy/down

# ── Database (API keys + usage tracking) ─────────────────────────────────────
database:
  path: "./qbert0g.db"

# ── API-key auth ─────────────────────────────────────────────────────────────
auth:
  # Bootstrap admin key: created in the database (device "*") on first
  # startup if not already present. Manage further keys with `qbert0g keys`.
  # Changing this later ADDS a new admin; revoke old keys explicitly.
  api_key: "sample-only-your-secure-bootstrap-key"
  # gRPC metadata header clients send the key in.
  header: "api-key"

# ── Service-wide default caps (overridable per API key) ──────────────────────
limits:
  max_bytes_per_request: 16384
  max_bytes_per_day: 104857600   # 100 MB
  rate_limit_per_minute: 200

# ── Post-processing ──────────────────────────────────────────────────────────
post_processing:
  # raw | sha256 | raw_samples  (maps to qcc-cli -P 1 | 0 | 2).
  # Entropy-research deployments (e.g. qthought) REQUIRE raw — SHA-256
  # launders away exactly the signal they study. Devices may override
  # individually via devices[].post_processing.
  mode: raw

# ── Freshness (the just-in-time measurement contract) ────────────────────────
freshness:
  # Flush the serial device read buffer immediately before EVERY measurement
  # so no byte measured before the request is ever served.
  flush_device_buffer: true
  # Stamp responses with the measurement time (RandomResponse.timestamp in µs,
  # EntropyResponse.generation_timestamp_ns in ns).
  emit_generation_timestamp: true
  # Declarative guards: this server has no pooling/pre-generation to enable.
  # Setting either to true is refused at startup.
  allow_pooling: false
  allow_pregeneration: false

# ── Devices ──────────────────────────────────────────────────────────────────
# Types: firefly (PCIe serial), qcicada (USB), dragonfly (high-rate serial) —
# all driven via pyqcc — chardev (PCIe Dragonfly as a plain character device,
# see below) and mock (os.urandom; NOT quantum; dev/testing only).
devices:
  - id: "firefly-1"
    type: "firefly"
    path: "/dev/ttyACM0"
    enabled: true
    # streaming_mode: true        # keep the device in continuous mode
    # streaming_idle_timeout: 10  # minutes idle before sleeping (0 = never)
    # post_processing: raw        # per-device override of the global mode
  # - id: "dragonfly-0"
  #   type: "dragonfly"
  #   path: "/dev/ttyQRNG0"
  #   streaming_mode: true
  #   rate_mbit_s: 350            # informational (capacity notes)
  #
  # PCIe Dragonfly character device (/dev/qrngDF*). No pyqcc, no qcc-cli
  # post-processing chain — the server serves whatever the driver DMA
  # delivers (`post_processing` is rejected on this type). Reads are
  # blocking DMA transfers with no one-shot size limit.
  #
  # `pci_address` (optional but strongly recommended) enables, via sysfs
  # /sys/bus/pci/devices/<addr>/:
  #   - freshness flush: before EVERY measurement, `ready_count` (32-bit
  #     words) is read and ready_count*4 buffered bytes are drained, so no
  #     byte generated before the request is served;
  #   - health snapshot: `error_present` + `error_bits` are read once per
  #     measurement. WARNING: `error_bits` is CLEAR-ON-READ — Qbert0G must
  #     be the ONLY process reading it on this box, or error flags are
  #     silently swallowed by the other reader.
  # Without `pci_address`, freshness flush is unavailable for the device
  # (a one-time warning is logged).
  # - id: "dragonfly-0"
  #   type: "chardev"
  #   path: "/dev/qrngDF0"
  #   pci_address: "0000:09:00.0"
  # - id: "dragonfly-1"
  #   type: "chardev"
  #   path: "/dev/qrngDF1"
  #   pci_address: "0000:0a:00.0"
  #
  # - id: "mock-0"                # development only — loudly logged, NOT quantum
  #   type: "mock"

# ── PRNG control sources ─────────────────────────────────────────────────────
# Seeded pseudorandom sources — loudly NOT quantum. They exist as matched
# statistical controls for the quantum devices in experiment arms. `seed`
# is REQUIRED (128-bit hex: 0x + 32 digits; no silent time-seeding) so any
# served block is regenerable offline from (id, seed, stream_offset_bytes).
# API keys bind to control ids exactly like device ids
# (`qbert0g keys create --device prng-uniform-0`).
controls:
  - id: "prng-uniform-0"
    type: "prng_uniform"          # numpy PCG64 raw 64-bit output stream
    seed: "0x9e3779b97f4a7c15f39cc0605cedc834"
  # Order-1 byte Markov chain fitted to a specific quantum card's
  # statistical fingerprint. Fit the npz model from raw dumps with
  # scripts/fit_markov.py; the model file must exist and validate
  # (row-stochastic within 1e-9) when the server starts.
  # - id: "prng-markov-0"
  #   type: "prng_markov"
  #   model: "/etc/qthought/models/dragonfly-0_v17.npz"
  #   seed: "0x243f6a8885a308d313198a2e03707344"

# ── Profiles ─────────────────────────────────────────────────────────────────
# Named deterministic transforms over devices/controls (never over other
# profiles — no nesting). Devices, controls and profiles share ONE id
# namespace; API keys bind to any of them. Transforms (bit order: numpy
# unpackbits/packbits, MSB first within each byte):
#   identity(a)         — passthrough (a profile id fronting a plain device)
#   xnor(a, b)          — agreement: output bit = 1 where the inputs agree
#   parity(a; params)   — output bit i = XOR of input bits stride*i + t, t in taps
# Period-4 guard: a pairwise tap distance or a stride that is a multiple
# of 4 is REJECTED unless `params.allow_period4: true` — the hardware has
# a known period-4 periodicity, and same-phase taps would correlate with
# it. The escape hatch exists on purpose: the canonical phase-covering
# design below (taps hitting all four residues mod 4, stride 4) samples
# one bit from each phase per output bit and must opt in explicitly.
profiles:
  - id: "raw-firefly"
    transform: "identity"
    inputs: ["firefly-1"]
  # - id: "qq-match"              # agreement stream of two quantum cards
  #   transform: "xnor"
  #   inputs: ["dragonfly-0", "dragonfly-1"]
  # - id: "qp-match"              # quantum vs fitted-PRNG control arm
  #   transform: "xnor"
  #   inputs: ["dragonfly-0", "prng-markov-0"]
  # - id: "parity4-df0"
  #   transform: "parity"
  #   inputs: ["dragonfly-0"]
  #   params: { taps: [0, 9, 19, 30], stride: 4, allow_period4: true }

# Shared knobs for profile serving (paired reads). When BOTH xnor inputs
# are hardware devices, the server locks the two devices (lexicographic id
# order), flushes each once at request start, then reads alternating
# chunks of `chunk_bytes` with a monotonic-ns timestamp per chunk. The
# max over chunk pairs of |t_A - t_B| is logged to provenance as
# `max_pair_skew_ns`; if it exceeds `max_skew_ns` the response is served
# anyway but a WARNING is logged (data is not wrong, the simultaneity
# bound is just looser than intended). Profiles NEVER fail over: if an
# input is unavailable the request fails UNAVAILABLE — an experiment arm
# must never silently change composition.
profiles_defaults:
  chunk_bytes: 4096               # alternating paired-read chunk size
  max_skew_ns: 50000000           # pair-skew WARNING threshold (50 ms)

# ── Provenance log ───────────────────────────────────────────────────────────
# Append-only JSONL, ONE record per served request (all protocols AND
# `qbert0g profiles pull`): source id, protocol, sequence_id, served
# bytes, transform, per-input facts — hardware inputs carry raw_bytes /
# chunk timestamps / flushed_bytes / error_present / error_bits (from the
# chardev health snapshot); PRNG inputs carry seed / stream_offset_bytes /
# model_sha256, so any pseudorandom involvement is explicit and greppable
# (`"kind":"prng"`), and every PRNG-served block is regenerable offline.
provenance:
  path: "./provenance.jsonl"
  # strict: false (default) — a provenance write failure logs ERROR and
  # the request is still served. Set true for study runs: a request whose
  # provenance cannot be recorded then fails (gRPC INTERNAL).
  strict: false
